{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "installCommand": "npm ci",
  "outputDirectory": "dist",
  "framework": null,
  "rewrites": [
    { "source": "/api/:path*", "destination": "https://${BACKEND_URL}/api/:path*" },
    { "source": "/admin/:path*", "destination": "https://${BACKEND_URL}/admin/:path*" },
    { "source": "/apidocs/:path*", "destination": "https://${BACKEND_URL}/apidocs/:path*" },
    { "source": "/flasgger/:path*", "destination": "https://${BACKEND_URL}/flasgger/:path*" },
    { "source": "/((?!assets/).*)", "destination": "/index.html" }
  ]
}
