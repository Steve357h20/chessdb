# Flask
SECRET_KEY=your-secret-key-here
FLASK_ENV=development

# Database
DATABASE_URI=mysql+pymysql://root:password@localhost/chessdb_dev?charset=utf8mb4

# JWT
JWT_SECRET_KEY=your-jwt-secret-key-here

# Stockfish
STOCKFISH_PATH=stockfish
ANALYSIS_DEPTH=20
ANALYSIS_TIMEOUT=300
ANALYSIS_THREADS=1
ANALYSIS_HASH=256

# Upload
UPLOAD_FOLDER=./uploads
